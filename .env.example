# --- Runtime ---
APP_ENV=dev
LOG_LEVEL=INFO
TZ=UTC

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quant
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant
DATABASE_URL=postgresql+psycopg://quant:quant@localhost:5432/quant

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO/S3) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET_RAW=raw
S3_BUCKET_ARTIFACT=artifact
S3_BUCKET_REPORT=report

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5001

# --- Data source keys (optional) ---
TUSHARE_TOKEN=
AKSHARE_ENABLED=1
YFINANCE_ENABLED=1
FRED_API_KEY=

# --- Security ---
JWT_SECRET=change-me
ADMIN_APPROVAL_REQUIRED=1
