# --- Application env ---
APP_ENV=dev
LOG_LEVEL=INFO

# --- Postgres ---
POSTGRES_DB=quant
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant
# App-side connection (from host):
DATABASE_URL=postgresql+psycopg://quant:quant@localhost:5432/quant
# App-side connection (from inside compose network):
# DATABASE_URL=postgresql+psycopg://quant:quant@postgres:5432/quant

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO for dev; real S3 in prod) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET_ARTIFACT=artifact

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# --- Data source adapters (§7) ---
AKSHARE_TIMEOUT_SECONDS=10
YFINANCE_TIMEOUT_SECONDS=10
# License tag used when an adapter cannot self-identify. DO NOT override to a
# provider tag unless the data path is fully licensed. See deploy/README.md §9.
LICENSE_TAG_DEFAULT=INTERNAL_RESEARCH

# --- CI / tests ---
# Set to 1 to enable env-gated live adapter smoke tests (tests/unit/test_live_adapters.py).
# Leave unset locally to keep the suite offline.
# RUN_LIVE_ADAPTERS=1

# --- API / worker ports (host mapping) ---
API_PORT=8000
WORKER_METRICS_PORT=8001

# --- Prometheus / Grafana ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
